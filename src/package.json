    "worker:crustdata": "node src/workers/crustdataWorker.js",
    "worker:hunter": "node src/workers/hunterWorker.js",
    "workers": "node src/workers/crustdataWorker.js & node src/workers/hunterWorker.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "server": "node src/server.js"
  },
  
